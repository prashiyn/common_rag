# Copy to ".env" in this directory (repo root), or override with a ".env"
# in the current working directory when you start the app.
#
# Optional: secrets can instead live in "src/config/api_keys.env"
# or "config/api_keys.env" (relative to cwd) — loaded without overriding vars already set.

# --- Service ----------------------------------------------------------

# APP_NAME=llm-service
# DEBUG=false
# Verbose LiteLLM + llm_service debug logs (also enabled when DEBUG=true)
LITELLM_DEBUG=true
# Absolute or relative path to YAML config dir (groq_limits.yaml, llms.yaml).
# Leave unset to use ./src/config or ./config relative to cwd.
# CONFIG_DIR=

# Shared secret if the gateway enforces auth (see SERVICE_AUTH_TOKEN in code).
SERVICE_AUTH_TOKEN=

# --- Groq -------------------------------------------------------------

# Which row in src/config/groq_limits.yaml to use: FREE or DEV
GROQ_PLAN=FREE
GROQ_API_KEY=

# --- LLM providers (LiteLLM) — set the ones you use -----------------

OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- Ollama -----------------------------------------------------------

# LiteLLM Ollama provider and direct embedding HTTP.
# Compose overrides this to http://ollama:11434 — use localhost only for non-Docker runs.
OLLAMA_API_BASE=http://localhost:11434
