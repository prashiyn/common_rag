# Temporial Graph RAG - environment template
# Copy to .env before running:
#   cp .env.example .env

# Optional: YAML for per-task provider/model (defaults to ./llm_config.yaml at repo root)
# LLM_CONFIG_PATH=

# LLM service (llm-service) base URL
# Compose default:
LLM_SERVICE_BASE_URL=http://llm-service:8001
# Local non-compose alternative:
# LLM_SERVICE_BASE_URL=http://localhost:8001

# Auth mode for LLM service.
# Current deployment uses no auth. Keep as "none" for now.
# Future options can include "api_key" or "bearer".
LLM_SERVICE_AUTH_MODE=none

# Optional auth token/key (leave empty when auth mode is none)
LLM_SERVICE_AUTH_TOKEN=

# HTTP timeout for LLM service calls (seconds)
LLM_SERVICE_TIMEOUT_SECONDS=60

# Retry behavior for transient failures
LLM_SERVICE_MAX_RETRIES=3
LLM_SERVICE_RETRY_BASE_DELAY_MS=500
LLM_SERVICE_RETRY_MAX_DELAY_MS=5000

# Impact scoring controls
IMPACT_BLEND_WITH_MODEL=false
IMPACT_PRIOR_WEIGHT=0.7

# Neo4j settings
NEO4J_ENABLED=true
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
# Match repo-root `.env` when using unified compose; compose overrides USER/PASSWORD.
NEO4J_PASSWORD=changeme
NEO4J_DATABASE=neo4j
NEO4J_MAX_CONNECTION_POOL_SIZE=50
NEO4J_STORE_EMBEDDINGS=false
NEO4J_SNAPSHOT_VECTOR_SCAN_LIMIT=2000
# NEO4J_SNAPSHOT_VECTOR_INDEX=chunk_snapshot_embedding_idx

# Embedding + publish_date snapshot supersession controls
NEO4J_SNAPSHOT_EMBED_SUPERSESSION=true
NEO4J_SNAPSHOT_EMBED_SUPERSEDE_MIN_COSINE=0.92
NEO4J_SNAPSHOT_EMBED_SUPERSEDE_MAX_TARGETS=5
NEO4J_SNAPSHOT_EMBED_SUPERSEDE_SAME_CHUNK_ONLY=false

# Startup and optional assist flags
LLM_STARTUP_MODELS_CHECK=false
ENTITY_RESOLUTION_ASSIST_ENABLED=false

# Optional Redis URL for multi-step retrieval session transcripts
# REDIS_URL=redis://localhost:6379/0

# Weekly decay-suppression job pagination
DECAY_JOB_PAGE_SIZE=500
