# Temporial Graph RAG - environment template

# Optional: YAML for per-task provider/model (defaults to ./llm_config.yaml at repo root)
# LLM_CONFIG_PATH=

# LLM service (llm-service) base URL — align with deployment (e.g. Compose service name + port)
LLM_SERVICE_BASE_URL=http://localhost:8001

# Auth mode for LLM service.
# Current deployment uses no auth. Keep as "none" for now.
# Future options can include "api_key" or "bearer".
LLM_SERVICE_AUTH_MODE=none

# Optional auth token/key (leave empty when auth mode is none)
LLM_SERVICE_AUTH_TOKEN=

# HTTP timeout for LLM service calls (seconds)
LLM_SERVICE_TIMEOUT_SECONDS=60

# Retry behavior for transient failures
LLM_SERVICE_MAX_RETRIES=3
LLM_SERVICE_RETRY_BASE_DELAY_MS=500
LLM_SERVICE_RETRY_MAX_DELAY_MS=5000

# Impact scoring controls
# When true, blend ontology prior with model-provided impact fields from extraction output.
IMPACT_BLEND_WITH_MODEL=false
# Weight for ontology prior in blend [0,1]. Model weight is (1 - prior weight).
IMPACT_PRIOR_WEIGHT=0.7

# Neo4j (remote Docker Compose or Aura). Set NEO4J_ENABLED=true when ready.
NEO4J_ENABLED=false
# Run pytest Neo4j integration tests (tests/test_neo4j_isolation_integration.py) against the DB above.
# NEO4J_INTEGRATION_TEST=1
NEO4J_URI=bolt://neo4j-host:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme
# Neo4j 5+ database name (default single DB is usually "neo4j")
NEO4J_DATABASE=neo4j
# Optional: max connection pool size
NEO4J_MAX_CONNECTION_POOL_SIZE=50
# When true, persist embedding vectors on ChunkIngestSnapshot.embedding (for future vector RAG / invalidation).
NEO4J_STORE_EMBEDDINGS=false
# Max snapshots scanned in-memory for vector search when no Neo4j vector index is configured.
NEO4J_SNAPSHOT_VECTOR_SCAN_LIMIT=2000
# Optional Neo4j 5+ vector index name on ChunkIngestSnapshot.embedding (see Neo4j CREATE VECTOR INDEX docs).
# NEO4J_SNAPSHOT_VECTOR_INDEX=chunk_snapshot_embedding_idx

# Embedding + publish_date snapshot supersession (ontology supplies hours per canonical_event; these tune similarity).
NEO4J_SNAPSHOT_EMBED_SUPERSESSION=true
NEO4J_SNAPSHOT_EMBED_SUPERSEDE_MIN_COSINE=0.92
NEO4J_SNAPSHOT_EMBED_SUPERSEDE_MAX_TARGETS=5
NEO4J_SNAPSHOT_EMBED_SUPERSEDE_SAME_CHUNK_ONLY=false

# If true, on startup the app probes GET /llm/models and logs a warning on failure (plan §8.2).
LLM_STARTUP_MODELS_CHECK=false

# Optional: second LLM pass after extraction to merge/deduplicate entity mentions before graph write.
ENTITY_RESOLUTION_ASSIST_ENABLED=false

# Optional Redis URL for multi-step retrieval session transcripts (see retrieval.session_store).
# Leave unset to use in-memory only (single-process).
# REDIS_URL=redis://localhost:6379/0

# Weekly decay-suppression job pagination (``python -m temporial_graph_rag.jobs.decay_suppress_weekly``).
DECAY_JOB_PAGE_SIZE=500
