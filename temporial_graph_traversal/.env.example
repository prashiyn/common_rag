# temporial_graph_traversal environment template
# Copy to `.env` before running:
#   cp .env.example .env
#
# Unified compose: set Neo4j/Postgres secrets in repo-root `.env`; compose overrides
# NEO4J_USERNAME, NEO4J_PASSWORD (and pulls doc_processing URLs). Keep these URI values
# for the in-compose network (`neo4j` hostname).

# App
APP_NAME=Reference-Aware Query Engine
APP_ENV=docker
APP_HOST=0.0.0.0
APP_PORT=8090

# Neo4j
NEO4J_URI=bolt://neo4j:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=changeme
NEO4J_DATABASE=neo4j

# Collection aliases
COLLECTION_ALIASES=ril:RELIANCE,reliance:RELIANCE,infy:INFY,infosys:INFY

# Optional llm-service integration
LLM_SERVICE_BASE_URL=http://llm-service:8001
LLM_PROCESSING_TIMEOUT_SECONDS=120
LLM_CONFIG_PATH=llm_config.yaml

# --- Local/non-compose overrides (examples; comment out compose-oriented values above first) ---
# APP_ENV=development
# NEO4J_URI=bolt://localhost:7687
# LLM_SERVICE_BASE_URL=http://localhost:8001
