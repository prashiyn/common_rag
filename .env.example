# Repo-root secrets for `docker-compose.yml` (copy to `.env` and customize).
#
# Compose loads this file automatically for variable substitution (${VAR}); it is NOT
# passed wholesale into application containers unless you map values explicitly in YAML.
#
# Keep the same Postgres and Neo4j credentials in any per-service `.env` you use for
# local/non-compose runs, or omit secrets there and rely on compose `environment:` overrides.

# --- PostgreSQL (shared server; separate logical databases per app) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
# Database used for bootstrap healthchecks / init joins (typically `postgres`)
POSTGRES_BOOTSTRAP_DB=postgres
#
# Logical DB names (fin_rag uses Alembic; ra_literag uses Postgres for LightRAG / RAG-Anything — schema managed in-app).
POSTGRES_DB_FIN_RAG=fin_rag
POSTGRES_DB_RA_LITERAG=ra_literag
#
# Optional CSV override — should list every app database above.
# If unset, Compose builds this from POSTGRES_DB_FIN_RAG and POSTGRES_DB_RA_LITERAG.
# POSTGRES_CREATE_DATABASES=fin_rag,ra_literag

# --- Neo4j (neo4j service + all graph-backed apps) ---
NEO4J_USERNAME=neo4j
# Must be at least 8 characters (Neo4j 5 requirement; do not use `neo4j`).
NEO4J_PASSWORD=changeme

# --- Ollama (compose `ollama` service; pulls are manual — see README) ---
# Comma-separated models for `docker compose --profile ollama-bootstrap run --rm ollama_init`.
# Already-downloaded models on the volume are skipped; only missing ones are pulled.
OLLAMA_PULL_MODELS=nomic-embed-text-v2-moe:latest,ibm/granite3.3-vision:2b,ibm/granite-docling:latest,glm-ocr:latest,deepseek-ocr:latest
# Optional one-off pull without editing the line above:
# OLLAMA_PULL_MODELS_EXTRA=some-new-model:latest

# If DATABASE_URL ever includes special URL characters (@ : / etc.), URL-encode the password segment.
#
# After editing root secrets, propagate to service/*/ .env files with:
#   python scripts/sync_service_env_from_root.py
