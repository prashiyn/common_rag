# core_rag_graph environment template
# Copy to .env before running:
#   cp .env.example .env
#
# Neo4j Community edition note:
# - Keep NEO4J_DATABASE=neo4j
# - Isolation is done via collection_id (not separate Neo4j databases)

# Graph backend selection: networkx | neo4j
GRAPH_BACKEND=neo4j
GRAPH_DUAL_WRITE=false
GRAPH_SECONDARY_BACKEND=networkx
GRAPH_DUAL_WRITE_STRICT=true

# Neo4j configuration
# Compose default:
NEO4J_URI=bolt://neo4j:7687
# Local non-compose alternative:
# NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
# Match repo-root `.env` (NEO4J_PASSWORD / NEO4J_USERNAME) when using unified compose; compose overrides this block.
NEO4J_PASSWORD=changeme
NEO4J_DATABASE=neo4j

# Centralized LLM routing via doc_processing service
LLM_SERVICE_BASE_URL=http://llm-service:8001
# Local non-compose alternative:
# LLM_SERVICE_BASE_URL=http://localhost:8001
# Optional override (default: config/llm_config.yaml)
LLM_CONFIG_PATH=
