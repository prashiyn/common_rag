# App
APP_NAME=doc-processing
# true: FastAPI verbose errors, debug_print, and artifacts under DOC_PROCESSING_TEMP_DIR/debug
# (original file, converted markdown, each FFP pipeline step). Use for local debugging only.
DEBUG=false

# Config directory for YAML files (chunking.yaml, llm_config.yaml, OCR configs, etc.)
DOC_PROCESSING_CONFIG_DIR=./config

# Temp directory for downloaded documents; files must be deleted after processing
DOC_PROCESSING_TEMP_DIR=./data/temp

# XBRL taxonomy directory (used by Docling XBRL backend). Typically points to data/nse.
XBRL_TAXONOMY_DIR=./data/xrbl_cache



# Ollama for Docling VLM + picture description (API_OLLAMA). In Docker Compose use http://ollama:11434
OLLAMA_BASE_URL=http://ollama:11434
# llm-service for FFP chunking, GLM/DeepSeek OCR (POST /llm/complete), embeddings.
LLM_SERVICE_BASE_URL=http://localhost:8001
