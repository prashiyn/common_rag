    "/documents/pdf-to-markdown": {
      "post": {
        "tags": [
          "documents"
        ],
        "summary": "Pdf To Markdown Endpoint",
        "description": "Convert a PDF to markdown using Docling (easyocr or vlm backend) from file upload or URL.",
        "operationId": "pdf_to_markdown_endpoint_documents_pdf_to_markdown_post",
        "parameters": [
          {
            "name": "url",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string",
                  "format": "uri",
                  "minLength": 1,
                  "maxLength": 2083
                },
                {
                  "type": "null"
                }
              ],
              "title": "Url"
            }
          },
          {
            "name": "backend",
            "in": "query",
            "required": false,
            "schema": {
              "enum": [
                "easyocr",
                "vlm"
              ],
              "type": "string",
              "default": "easyocr",
              "title": "Backend"
            }
          },
          {
            "name": "merge_tables",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean",
              "default": false,
              "title": "Merge Tables"
            }
          }
        ],
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "$ref": "#/components/schemas/Body_pdf_to_markdown_endpoint_documents_pdf_to_markdown_post"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PdfToMarkdownResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
