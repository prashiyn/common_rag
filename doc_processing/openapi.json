                  "minLength": 1,
                  "maxLength": 2083
                },
                {
                  "type": "null"
                }
              ],
              "title": "Url"
            }
          }
        ],
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "$ref": "#/components/schemas/Body_convert_ms_docs_documents_convert_ms_docs_post"
