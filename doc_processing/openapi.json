    "/documents/convert-ms-docs": {
      "post": {
        "tags": [
          "documents"
        ],
        "summary": "Convert Ms Docs",
        "description": "Convert a Microsoft Office document (Word/Excel/PowerPoint) to markdown from file upload or URL.",
        "operationId": "convert_ms_docs_documents_convert_ms_docs_post",
        "parameters": [
          {
            "name": "url",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string",
