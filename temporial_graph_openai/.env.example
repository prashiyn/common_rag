# --- Neo4j ---
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
# Match repo-root `.env` when using unified compose; compose overrides USER/PASSWORD.
NEO4J_PASSWORD=changeme
# Optional: Neo4j database name (Neo4j 4.4+ multi-database)
NEO4J_DATABASE=neo4j

# --- App ---
TEMPORAL_GRAPH_API_HOST=0.0.0.0
TEMPORAL_GRAPH_API_PORT=8080
# Path to repo-root relative configs
LLM_CONFIG_PATH=llm_config.yml
ONTOLOGIES_DIR=ontologies
PREDICATES_PATH=predicates/default.yml
PREDICATE_GROUPS_PATH=predicates/groups.yml

# --- doc-processing service (LLM + embeddings proxy) ---
LLM_SERVICE_BASE_URL=http://llm-service:8001
LLM_PROCESSING_TIMEOUT_SECONDS=120
LLM_PROCESSING_CONNECT_TIMEOUT_SECONDS=10
LLM_PROCESSING_MAX_RETRIES=3
LLM_PROCESSING_RETRY_BACKOFF_SECONDS=0.5

# --- Ingestion jobs ---
# memory = in-process asyncio tasks; redis = shared queue + job hash (multi-worker)
JOB_BACKEND=memory
REDIS_URL=redis://127.0.0.1:6379/0
REDIS_JOB_QUEUE_KEY=ingest:queue
REDIS_JOB_KEY_PREFIX=ingest:job
# When JOB_BACKEND=redis, each API process can run a BRPOP worker (set false if you use a dedicated worker only)
INGEST_START_REDIS_WORKER=true
# Max concurrent background ingest jobs (per worker process)
INGEST_MAX_CONCURRENT_JOBS=2
# Shared secret for optional HMAC on outbound job webhooks (leave empty to skip signing)
JOB_WEBHOOK_SIGNING_SECRET=

# --- Temporal invalidation (ontology overrides per subevent; this is global fallback) ---
DEFAULT_INVALIDATION_PUBLISH_DATE_THRESHOLD_HOURS=12

# --- Direct OpenAI (optional fallback when a role sets provider=openai_direct) ---
OPENAI_API_KEY=
